"pada_1_2": [
    { "id": "1.2.1", "name": "✨ गाङ्कुटादिभ्योऽञ्णिन्ङित्", "desc": "गाङ् आदेश और कुटादि धातुओं के बाद यदि 'ञित्' और 'णित्' को छोड़कर अन्य प्रत्यय आते हैं, तो वे 'ङित्' के समान होते हैं।" },
    { "id": "1.2.2", "name": "✨ विज इट्", "desc": "'ओविजी' धातु से विहित इडादि (इट् आदि) प्रत्यय विकल्प से ङित् होते हैं।" },
    { "id": "1.2.3", "name": "✨ विभाषोर्णोः", "desc": "ऊर्णु धातु के बाद इडादि प्रत्यय विकल्प से ङित् होते हैं।" },
    { "id": "1.2.4", "name": "✨ सार्वधातुकमपित्", "desc": "पित् (तिप्, सिप्, मिप्) को छोड़कर शेष सार्वधातुक प्रत्यय ङित् होते हैं।" },
    { "id": "1.2.5", "name": "✨ असंयोगाल्लिट् कित्", "desc": "असंयोगान्त धातु से अपित् लिट् प्रत्यय कित् होता है।" },
    { "id": "1.2.6", "name": "✨ इन्धिभवतिभ्यां च", "desc": "ईन्ध् तथा भू धातु से परे विहित लिट् प्रत्यय भी कित् होता है।" },
    { "id": "1.2.7", "name": "✨ मृडमृदगुधकुषक्लिश्शवदवसः क्त्वा", "desc": "मृड्, मृद्, गुध्, कुष्, क्लिश्, वद्, वस् - इन धातुओं से विहित क्त्वा प्रत्यय कित् होता है।" },
    { "id": "1.2.8", "name": "✨ रुदविदमुषग्रहिस्वपिप्रच्छः सञ्च", "desc": "रुद्, विद्, मुष्, ग्रह्, स्वप्, प्रच्छ् - इन धातुओं से विहित क्त्वा तथा सन् प्रत्यय कित् होते हैं।" },
    { "id": "1.2.9", "name": "✨ इको झल्", "desc": "इगन्त धातु के बाद झलादि सन् कित् होता है।" },
    { "id": "1.2.10", "name": "✨ हलन्ताच्च", "desc": "इक् के समीपवर्ती हल् से परे झलादि सन् कित् होता है।" },
    { "id": "1.2.11", "name": "✨ लिङ् सिचावात्मनेपदेषु", "desc": "इक् के समीपवर्ती हल् से परे आत्मनेपद-विषयक झलादि लिङ् और सिच् कित् होते हैं।" },
    { "id": "1.2.12", "name": "✨ उश्च", "desc": "ऋवर्ण से परे झलादि लिङ् और सिच् आत्मनेपद में कित् होते हैं।" },
    { "id": "1.2.13", "name": "✨ वा गमः", "desc": "'गम्' धातु से विहित झलादि लिङ्-सिच् आत्मनेपद में विकल्प से कित् होते हैं।" },
    { "id": "1.2.14", "name": "✨ हनः सिच्", "desc": "'हन्' धातु से विहित सिच् आत्मनेपद में कित् होता है।" },
    { "id": "1.2.15", "name": "✨ यमो गन्धने", "desc": "दोष उद्घाटन अर्थ में प्रयुज्यमान यम् धातु से विहित सिच् आत्मनेपद में कित् होता है।" },
    { "id": "1.2.16", "name": "✨ विभाषोपयमने", "desc": "विवाहार्थक 'यम्' धातु से विहित सिच् आत्मनेपद में विकल्प से कित् होता है।" },
    { "id": "1.2.17", "name": "✨ स्थाघ्वोरिच्च", "desc": "आत्मनेपद प्रत्यय होने पर स्था और घु-संज्ञक धातु के स्थान पर इकार होता है तथा सिच् कित् होता है।" },
    { "id": "1.2.18", "name": "✨ न क्त्वा सेट्", "desc": "इट् सहित क्त्वा प्रत्यय कित् नहीं होता।" },
    { "id": "1.2.19", "name": "✨ निष्ठा शीङ्स्विदिमिदिक्ष्विदिधृषः", "desc": "शीङ्, स्विद्, मिद्, क्ष्विद् तथा धृष् धातुओं से विहित इडागम-विशिष्ट निष्ठा प्रत्यय कित् नहीं होता।" },
    { "id": "1.2.20", "name": "✨ मृषस्तितिक्षायाम्", "desc": "क्षमार्थक 'मृष्' धातु से विहित इडागम-विशिष्ट निष्ठा प्रत्यय कित् नहीं होता।" },
    { "id": "1.2.21", "name": "✨ उदुपधाद्भावादिकर्मणोरन्यतरस्याम्", "desc": "उकार उपधा वाली धातु से भाव तथा आदिकर्म में विहित सेट् निष्ठा प्रत्यय विकल्प से कित् नहीं होता।" },
    { "id": "1.2.22", "name": "✨ पूङः क्त्वा च", "desc": "'पूङ्' धातु से विहित सेट् क्त्वा तथा निष्ठा प्रत्यय कित् नहीं होते हैं।" },
    { "id": "1.2.23", "name": "✨ नोपधात्थफान्ताद्वा", "desc": "नकार उपधा वाली, तथा थकारान्त एवं फकारान्त धातुओं से विहित सेट् क्त्वा विकल्प से कित् नहीं होता।" },
    { "id": "1.2.24", "name": "✨ वञ्चिलुञ्च्यृतश्च", "desc": "वञ्च्, लुञ्च् तथा ऋत् धातुओं से विहित सेट् क्त्वा प्रत्यय विकल्प से कित् नहीं होता।" },
    { "id": "1.2.25", "name": "✨ तृषिमृषिकृशेः काश्यपस्य", "desc": "तृष्, मृष् तथा कृश् धातुओं से विहित सेट् क्त्वा काश्यप मुनि के मत में विकल्प से कित् नहीं होता।" },
    { "id": "1.2.26", "name": "✨ रलो व्युपधाद्धलादेः सञ्च", "desc": "इ/उ उपधा वाली, हलादि और रलन्त धातु के पश्चात् इट् सहित क्त्वा और सन् विकल्प से कित् होते हैं।" },
    { "id": "1.2.27", "name": "✨ ऊकालोऽज्झ्रस्वदीर्घप्लुतः", "desc": "उ, ऊ और ऊ३ काल वाले अच् (स्वर) क्रमशः ह्रस्व, दीर्घ और प्लुत संज्ञक होते हैं।" },
    { "id": "1.2.28", "name": "✨ अचश्च", "desc": "ह्रस्व, दीर्घ तथा प्लुत संज्ञाएँ केवल अच् (स्वर) की ही होती हैं।" },
    { "id": "1.2.29", "name": "✨ उच्चैरुदात्तः", "desc": "कण्ठ, तालु आदि स्थानों के उपरि भाग से उच्चरित अच् उदात्त कहलाता है।" },
    { "id": "1.2.30", "name": "✨ नीचैरनुदात्तः", "desc": "कण्ठ, तालु आदि स्थानों के निचले भाग से उच्चरित अच् अनुदात्त कहलाता है।" },
    { "id": "1.2.31", "name": "✨ समाहारः स्वरितः", "desc": "उदात्त और अनुदात्त वर्ण-धर्मों का जहाँ समाहार हो, वह अच् स्वरित कहलाता है।" },
    { "id": "1.2.32", "name": "✨ तस्यादित उदात्तमर्धह्रस्वम्", "desc": "स्वरित स्वर के प्रारम्भ का अर्ध-ह्रस्व भाग उदात्त होता है और शेषांश अनुदात्त।" },
    { "id": "1.2.33", "name": "✨ एकश्रुति दूरात्सम्बुद्धौ", "desc": "दूर से सम्बोधन किये जाने पर वाक्य के सभी स्वरों की एकश्रुति (समान उच्चारण) होती है।" },
    { "id": "1.2.34", "name": "✨ यज्ञकर्मण्यजपन्यूङ्खसामसु", "desc": "जप, न्यूङ्ख तथा साम को छोड़कर यज्ञकर्म में सभी स्वरों की एकश्रुति होती है।" },
    { "id": "1.2.35", "name": "✨ उच्चैस्तरां वा वषट्कारः", "desc": "यज्ञकर्म में 'वौषट्' विकल्प से उदात्ततर होता है, पक्ष में एकश्रुति होती है।" },
    { "id": "1.2.36", "name": "✨ विभाषा छन्दसि", "desc": "वेद में विकल्प से तीनों स्वरों की एकश्रुति भी होती है और त्रैस्वर्य भी।" },
    { "id": "1.2.37", "name": "✨ न सुब्रह्मण्यायां स्वरितस्य तूदात्तः", "desc": "'सुब्रह्मण्या' निगद में एकश्रुति नहीं होती, किन्तु स्वरित के स्थान पर उदात्त हो जाता है।" },
    { "id": "1.2.38", "name": "✨ देवब्रह्मणोरनुदात्तः", "desc": "'सुब्रह्मण्या' निगद में 'देव' तथा 'ब्रह्मन्' शब्दों के स्वरित के स्थान पर अनुदात्त हो जाता है।" },
    { "id": "1.2.39", "name": "✨ स्वरितात्संहितायामनुदात्तानाम्", "desc": "संहिता होने पर स्वरित के परवर्ती अनुदात्तों की एकश्रुति हो जाती है।" },
    { "id": "1.2.40", "name": "✨ उदात्तस्वरितपरस्य सन्नतरः", "desc": "उदात्त तथा स्वरित से पूर्ववर्ती अनुदात्त सन्नतर (अधिक अनुदात्त) हो जाता है।" },
    { "id": "1.2.41", "name": "✨ अपृक्त एकाल्प्रत्ययः", "desc": "एक वर्ण (अल्) वाले प्रत्यय की अपृक्त संज्ञा होती है (जैसे 'सु' का 'स्')." },
    { "id": "1.2.42", "name": "✨ तत्पुरुषः समानाधिकरणः कर्मधारयः", "desc": "समानाधिकरण (समान विभक्ति वाले) तत्पुरुष समास की 'कर्मधारय' संज्ञा होती है।" },
    { "id": "1.2.43", "name": "✨ प्रथमानिर्दिष्टं समास उपसर्जनम्", "desc": "समास विधायक सूत्र में प्रथमा विभक्ति से निर्दिष्ट शब्द की 'उपसर्जन' संज्ञा होती है।" },
    { "id": "1.2.44", "name": "✨ एकविभक्ति चापूर्वनिपाते", "desc": "समास-विग्रह में जिसकी विभक्ति एक ही रहती है (बदलती नहीं), वह भी उपसर्जन कहलाता है।" },
    { "id": "1.2.45", "name": "✨ अर्थवदधातुरप्रत्ययः प्रातिपदिकम्", "desc": "धातु, प्रत्यय और प्रत्ययान्त को छोड़कर अन्य अर्थवान् शब्द-स्वरूप की प्रातिपदिक संज्ञा होती है।" },
    { "id": "1.2.46", "name": "✨ कृत्तद्धितसमासाश्च", "desc": "कृदन्त, तद्धितान्त व समास की भी प्रातिपदिक संज्ञा होती है।" },
    { "id": "1.2.47", "name": "✨ ह्रस्वो नपुंसके प्रातिपदिकस्य", "desc": "अजन्त नपुंसक प्रातिपदिक के अन्तिम स्वर को ह्रस्व आदेश होता है।" },
    { "id": "1.2.48", "name": "✨ गोस्त्रियोरुपसर्जनस्य", "desc": "जिस प्रातिपदिक के अन्त में उपसर्जन-संज्ञक 'गो' या स्त्री-प्रत्ययान्त शब्द हो, उसका ह्रस्व होता है।" },
    { "id": "1.2.49", "name": "✨ लुक् तद्धितलुकि", "desc": "तद्धित प्रत्यय के लुक् होने पर उपसर्जन स्त्री-प्रत्यय का भी लुक् हो जाता है।" },
    { "id": "1.2.50", "name": "✨ इद्गोण्याः", "desc": "तद्धित प्रत्यय के लुक् होने पर 'गोणी' शब्द के स्त्री-प्रत्यय को इकार अन्तादेश हो जाता है।" },
    { "id": "1.2.51", "name": "✨ लुपि युक्तवद्व्यक्तिवचने", "desc": "लुप् प्रत्यय-लोप होने पर लिङ्ग और वचन प्रकृति के समान ही होते हैं।" },
    { "id": "1.2.52", "name": "✨ विशेषणानां चाजातेः", "desc": "जातिभिन्न विशेषणों की लिङ्ग-संख्या भी प्रकृति के समान ही होती है।" },
    { "id": "1.2.53", "name": "✨ तदशिष्यं संज्ञाप्रमाणत्वात्", "desc": "लिङ्ग और वचन लोकव्यवहार के अधीन हैं, अतः इनका व्याकरण से पूर्ण अनुशासन अनावश्यक है।" },
    { "id": "1.2.54", "name": "✨ लुब्योगाप्रख्यानात्", "desc": "सम्बन्ध की प्रतीति न होने पर 'लुप्' विधान नहीं करना चाहिए।" },
    { "id": "1.2.55", "name": "✨ योगप्रमाणे च तदभावेऽदर्शनं स्यात्", "desc": "सम्बन्ध की प्रतीति प्रामाणिक होने पर सम्बन्धाभाव में उन शब्दों का प्रयोग नहीं होता।" },
    { "id": "1.2.56", "name": "✨ प्रधानप्रत्ययार्थवचनस्यान्यप्रमाणत्वात्", "desc": "समास में प्रधानत्व आदि की व्यवस्था लोकाधीन है, अतः व्याकरण में उपदेश अनावश्यक है।" },
    { "id": "1.2.57", "name": "✨ कालोपसर्जने च तुल्यम्", "desc": "काल तथा उपसर्जन का निर्देश भी लोक-व्यवहार के तुल्य है।" },
    { "id": "1.2.58", "name": "✨ जात्याख्यायामेकस्मिन् बहुवचनमन्यतरस्याम्", "desc": "जाति की विवक्षा में एकवचन के स्थान पर विकल्प से बहुवचन भी होता है (जैसे सम्पन्नो यवः / सम्पन्ना यवाः)।" },
    { "id": "1.2.59", "name": "✨ अस्मदो द्वयोश्च", "desc": "'अस्मद्' (मैं) शब्द के एकवचन तथा द्विवचन के स्थान पर विकल्प से बहुवचन होता है (अहं/वयं ब्रूमः)।" },
    { "id": "1.2.60", "name": "✨ फल्गुनीप्रोष्ठपदानां च नक्षत्रे", "desc": "फाल्गुनी और प्रोष्ठपदा नक्षत्रों के द्विवचन के स्थान पर विकल्प से बहुवचन होता है।" },
    { "id": "1.2.61", "name": "✨ छन्दसि पुनर्वस्वोरेकवचनम्", "desc": "वेद में पुनर्वसु के द्विवचन के स्थान पर विकल्प से एकवचन होता है।" },
    { "id": "1.2.62", "name": "✨ विशाखयोश्च", "desc": "वेद में विशाखा नक्षत्र के द्विवचन के स्थान पर विकल्प से एकवचन होता है।" },
    { "id": "1.2.63", "name": "✨ तिष्यपुनर्वस्वोर्नक्षत्रद्वन्द्वे बहुवचनस्य द्विवचनं नित्यम्", "desc": "तिष्य-पुनर्वसू के द्वन्द्व समास में बहुवचन के स्थान पर नित्य द्विवचन ही होता है।" },
    { "id": "1.2.64", "name": "✨ सरूपाणामेकशेष एकविभक्तौ", "desc": "समान विभक्ति परे रहने पर समान रूप वाले शब्दों का एक ही रूप शेष रहता है (रामश्च रामश्च = रामौ)।" },
    { "id": "1.2.65", "name": "✨ वृद्धो यूना तल्लक्षणश्चेदेव विशेषः", "desc": "वृद्ध (गोत्र) और युव प्रत्ययान्त शब्दों के सहप्रयोग में गोत्र शब्द ही शेष रहता है (गार्ग्यौ)।" },
    { "id": "1.2.66", "name": "✨ स्त्री पुंवच्च", "desc": "गोत्र स्त्रीलिङ्ग और युव पुँल्लिङ्ग के सहप्रयोग में स्त्रीलिङ्ग शब्द शेष रहता है और पुंवद्भाव होता है।" },
    { "id": "1.2.67", "name": "✨ पुमान् स्त्रिया", "desc": "स्त्रीलिङ्ग और पुँल्लिङ्ग शब्द के सहप्रयोग में पुँल्लिङ्ग शब्द ही शेष रहता है (ब्राह्मणौ)।" },
    { "id": "1.2.68", "name": "✨ भ्रातृपुत्रौ स्वसृदुहितृभ्याम्", "desc": "भ्राता-स्वसा तथा पुत्र-दुहिता के सहप्रयोग में क्रमशः भ्राता और पुत्र शेष रहते हैं (भ्रातरौ, पुत्रौ)।" },
    { "id": "1.2.69", "name": "✨ नपुंसकमनपुंसकेनैकवच्चास्यान्यतरस्याम्", "desc": "नपुंसक और अनपुंसक के सहप्रयोग में नपुंसक विकल्प से शेष रहता है और एकवचन होता है।" },
    { "id": "1.2.70", "name": "✨ पिता मात्रा", "desc": "माता के साथ कथन होने पर पिता पद विकल्प से शेष रह जाता है (पितरौ)।" },
    { "id": "1.2.71", "name": "✨ श्वशुरः श्वश्र्वा", "desc": "श्वश्रू और श्वशुर के सहप्रयोग में श्वशुर शब्द विकल्प से शेष रहता है (श्वशुरौ)।" },
    { "id": "1.2.72", "name": "✨ त्यदादीनि सर्वैर्नित्यम्", "desc": "किसी भी शब्द के साथ प्रयुज्यमान होने पर त्यदादि (तद् आदि) शब्द ही नित्य शेष रहते हैं (तौ)।" },
    { "id": "1.2.73", "name": "✨ ग्राम्यपशुसङ्घेष्वतरुणेषु स्त्री", "desc": "ग्राम्यपशुओं (अतरुण) के वाचक शब्दों के सहप्रयोग में स्त्रीलिङ्ग पशु-वाचक शब्द शेष रहता है (गावः)।" }
  ]
